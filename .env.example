# ===========================================
# WhooshMD Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Omnidim Voice Agent Configuration (Required for voice calls)
# Contact Omnidim for API access: https://omnidim.com
OMNIDIM_API_KEY=your_omnidim_api_key
OMNIDIM_API_URL=https://api.omnidim.com/v1
OMNIDIM_AGENT_ID=1060

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Voice Call Configuration
# Set to 'true' to enable mock mode (no real calls made)
NEXT_PUBLIC_CALL_DISPATCH_MOCK=true

# Webhook Configuration (for Omnidim callbacks)
NEXT_PUBLIC_WEBHOOK_URL=http://localhost:3000/api/webhook/call-result
